rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Fields:
    //   - name: string (required)
    //   - barcode: string (optional)
    //   - category: string (optional)
    //   - price: number (required)
    //   - cost: number (optional)
    //   - stock: number (required)
    //   - minStock: number (optional)
    //   - updatedAt: timestamp (required)
    //
    // Collection: sales
    // Fields:
    //   - items: list (required)
    //   - total: number (required)
    //   - paymentMethod: string (required)
    //   - timestamp: timestamp (required)
    //   - userId: string (required)
    //   - shiftId: string (required)
    //   - cashierName: string (optional)
    //   - amountPaid: number (required)
    //   - change: number (required)
    //
    // Collection: shifts
    // Fields:
    //   - cashierName: string (required)
    //   - startTime: timestamp (required)
    //   - endTime: timestamp (optional)
    //   - initialCash: number (optional)
    //   - finalCash: number (optional)
    //   - totalSales: number (optional)
    //   - status: string (required)
    //   - userId: string (required)
    //
    // Collection: users
    // Fields:
    //   - email: string (required)
    //   - role: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "soriav449veronica@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isStaff() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'staff'] ||
        isAdmin()
      );
    }

    // Validation Functions
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.stock is number &&
             data.updatedAt is timestamp;
    }

    function isValidSale(data) {
      return data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.timestamp is timestamp &&
             data.userId == request.auth.uid &&
             data.shiftId is string &&
             data.amountPaid is number && data.amountPaid >= 0 &&
             data.change is number && data.change >= 0;
    }

    function isValidShift(data) {
      return data.cashierName is string && data.cashierName.size() > 0 &&
             data.startTime is timestamp &&
             data.status in ['open', 'closed'] &&
             data.userId == request.auth.uid;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create, update: if isStaff() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if isStaff();
      allow create: if isStaff() && isValidSale(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /shifts/{shiftId} {
      allow read: if isStaff();
      allow create: if isStaff() && isValidShift(request.resource.data);
      allow update: if isStaff() && isValidShift(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}

{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available in the kiosk.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "barcode": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "stock": { "type": "number" },
        "minStock": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stock"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A transaction record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" },
              "subtotal": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["cash", "card", "transfer"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "shiftId": { "type": "string" },
        "cashierName": { "type": "string" },
        "amountPaid": { "type": "number" },
        "change": { "type": "number" }
      },
      "required": ["items", "total", "timestamp", "shiftId"]
    },
    "Shift": {
      "title": "Shift",
      "description": "A work shift record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "cashierName": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "initialCash": { "type": "number" },
        "finalCash": { "type": "number" },
        "totalSales": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "userId": { "type": "string" }
      },
      "required": ["cashierName", "startTime", "status", "userId"]
    },
    "User": {
      "title": "User",
      "description": "A user of the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of kiosk products."
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Collection of sales transactions."
    },
    "/shifts/{shiftId}": {
      "schema": "Shift",
      "description": "Collection of work shifts."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    }
  }
}
